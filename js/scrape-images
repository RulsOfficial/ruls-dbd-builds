const fs = require('fs');
const path = require('path');
const { JSDOM } = require('jsdom');
const axios = require("axios").default;

// 🔹 Función que extrae TODAS las imágenes de una página
async function extractImages(url) {
    const response = await axios.get(url);
    const dom = new JSDOM(response.data);
    const { document } = dom.window;

    // Sacar todas las imágenes
    const imgs = [...document.querySelectorAll("img")]
        .map(img => img.getAttribute("src"))
        .filter(Boolean) // eliminar null/undefined
        .map(src => {
            // Normalizar a URL absoluta
            if (src.startsWith("http")) {
                return src;
            } else if (src.startsWith("//")) {
                return "https:" + src;
            } else {
                return new URL(src, url).href;
            }
        });

    return [...new Set(imgs)]; // quitar duplicados
}

// 🔹 Main
(async function () {
    try {
        const targetUrl = "https://deadbydaylight.wiki.gg/wiki/Killer_Perks"; // cambia la URL aquí
        console.log(`⏳ Descargando imágenes desde: ${targetUrl}`);

        const images = await extractImages(targetUrl);

        const dataDir = path.join(__dirname, "..", "data");
        if (!fs.existsSync(dataDir)) fs.mkdirSync(dataDir, { recursive: true });

        const outFile = path.join(dataDir, "images.json");
        fs.writeFileSync(outFile, JSON.stringify(images, null, 2));

        console.log(`✅ ${images.length} imágenes encontradas. Guardadas en ${outFile}`);
    } catch (err) {
        console.error("❌ Error:", err);
    }
})();
